# ===========================================
# PlaidCas Casino Configuration
# ===========================================

# Site Configuration
NEXT_PUBLIC_APP_URL=https://yourdomain.com
NEXT_PUBLIC_SITE_NAME=Your Casino
CASINO_NAME=Your Casino

# Database (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/casino

# PLAIDEX Payment API
PLAIDEX_API_KEY=your_plaidex_api_key
PLAIDEX_API_SECRET=your_plaidex_api_secret

# ===========================================
# Telegram Bot Settings
# ===========================================
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_BOT_USERNAME=your_bot_username

# Admin Settings (comma-separated Telegram user IDs)
ADMIN_IDS=123456789,987654321
SUPER_ADMIN_IDS=111111111
NEXT_PUBLIC_ADMIN_IDS=123456789,987654321
NEXT_PUBLIC_SUPER_ADMIN_IDS=111111111

# ===========================================
# Casino Settings
# ===========================================
MIN_BET=10
MAX_BET=500000
DEFAULT_BALANCE=0

# Payment Settings
CASINO_TON_WALLET=your_ton_wallet_address
NEXT_PUBLIC_CASINO_TON_WALLET=your_ton_wallet_address

# Feature Flags
ENABLE_TON_PAYMENTS=true
ENABLE_SBP_PAYMENTS=false
ENABLE_BONUSES=true
ENABLE_REFERRALS=true
MAINTENANCE_MODE=false

# Deposit Limits
MIN_DEPOSIT=50
MAX_DEPOSIT=50000